# Адрес backend Strapi, доступный из браузера.
# Локально:
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337
# В продакшене (Coolify) задать публичный домен бэкенда, например:
# NEXT_PUBLIC_STRAPI_URL=https://api-tracer.example.com

# Порт прослушивания. Локально dev = 3100 (см. package.json).
# В продакшене порт берётся из переменной PORT (next start).
# PORT=3000
