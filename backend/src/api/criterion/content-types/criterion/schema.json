{
  "kind": "collectionType",
  "collectionName": "criteria",
  "info": {
    "singularName": "criterion",
    "pluralName": "criteria",
    "displayName": "Критерий",
    "description": "Критерий (вопрос) опросника"
  },
  "options": {
