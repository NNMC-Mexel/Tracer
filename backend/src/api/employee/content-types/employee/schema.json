{
  "kind": "collectionType",
  "collectionName": "employees",
  "info": {
    "singularName": "employee",
    "pluralName": "employees",
    "displayName": "Сотрудник",
    "description": "Сотрудник организации (справочник для проведения трейсеров)"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "fullName": {
      "type": "string",
      "required": true
    },
    "position": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "description": "Категория персонала (для выбора опросника). Заполняется позже."
    },
    "organization": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::organization.organization",
      "inversedBy": "employees"
    },
    "department": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::department.department",
      "inversedBy": "employees"
    },
    "active": {
      "type": "boolean",
      "default": true
    }
  }
}
